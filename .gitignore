*.mp4
!assets/Microsoft365 & Entra ID Demo Video.mp4
*.mov
*.avi
*.mkv

# Secrets and private keys
*.key
*.pem
*.pfx
*.p12
*secret*
*credential*
*token*
*apikey*
*api-key*

# Local PowerShell history/config
ConsoleHost_history.txt
